#!/usr/bin/env bash
# Script to configure Nginx with custom X-Served-By HTTP response header

# Update package lists
sudo apt-get update

# Install Nginx if not already installed
sudo apt-get install -y nginx

# Get the current hostname
HOSTNAME=$(hostname)

# Add the custom header to Nginx default configuration
# First, check if the header already exists
if ! grep -q "add_header X-Served-By" /etc/nginx/sites-available/default; then
    # Add the header after the server_name directive
    sudo sed -i '/server_name _;/a\    add_header X-Served-By '"$HOSTNAME"' always;' /etc/nginx/sites-available/default
fi

# Test Nginx configuration
sudo nginx -t

# Reload Nginx to apply changes
sudo service nginx reload

# Verify the header is working
curl -sI http://localhost | grep X-Served-By
