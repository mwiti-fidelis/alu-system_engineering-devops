#!/usr/bin/env bash
# Configures a new Ubuntu machine with a custom Nginx response header

# Update package list and install nginx
apt-get update
apt-get -y install nginx

# Add the custom header to the Nginx configuration file
sed -i "/server_name _;/a \ \ \ \ add_header X-Served-By \$HOSTNAME;" /etc/nginx/sites-available/default

# Restart Nginx to apply changes
service nginx restart
