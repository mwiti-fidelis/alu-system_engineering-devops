#!/usr/bin/env bash
# Install nginx and add custom header X-Served-By

apt-get update -y
apt-get install -y nginx

# Add custom header to nginx configuration
# The $hostname variable will be interpreted by nginx, not bash
sed -i '/server_name _;/a\        add_header X-Served-By $hostname;' /etc/nginx/sites-available/default

service nginx restart