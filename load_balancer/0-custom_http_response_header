#!/usr/bin/env bash
# Configures Nginx with a single custom X-Served-By header

# Ensure Nginx is installed
apt-get update -y
apt-get install -y nginx

# 1. Remove any existing lines containing X-Served-By to prevent duplicates
sed -i '/add_header X-Served-By/d' /etc/nginx/sites-available/default

sed -i "/server_name _;/a \ \ \ \ add_header X-Served-By \$hostname;" /etc/nginx/sites-available/default

# 3. Restart Nginx to apply the clean configuration
service nginx restart