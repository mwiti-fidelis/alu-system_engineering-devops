#!/usr/bin/env bash
# Script to configure Nginx with custom X-Served-By HTTP response header

# Update package lists
sudo apt-get update

# Install Nginx if not already installed
sudo apt-get install -y nginx

# Get the hostname
HOSTNAME=$(hostname)

# Create Nginx configuration with custom header
cat << EOF | sudo tee /etc/nginx/conf.d/custom_header.conf
# Add custom X-Served-By header to all responses
add_header X-Served-By \$hostname always;
EOF

# Alternative: Modify the default site configuration
# Backup the original configuration
sudo cp /etc/nginx/sites-available/default /etc/nginx/sites-available/default.bak

# Add the custom header to the default server block
sudo sed -i '/server_name _;/a\    add_header X-Served-By '"$HOSTNAME"' always;' /etc/nginx/sites-available/default

# Test Nginx configuration
sudo nginx -t

# Restart Nginx to apply changes
sudo service nginx restart

# Verify the header is working
echo "Testing custom header configuration..."
curl -sI http://localhost | grep X-Served-By
